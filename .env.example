# ─── OpenRouter (free model) ───────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/stepfun/step-3.5-flash:free

# ─── Together.ai (CV + cover letter writing only) ──────────────────────────
TOGETHER_API_KEY=your_together_api_key_here
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_BUDGET_USD=10.00
TOGETHER_WARN_AT_USD=1.00

# ─── Processing LLM (LiteLLM / Ollama) ────────────────────────────────────
PROC_LLM_BASE_URL=http://localhost:11434
PROC_LLM_MODEL=qwen2.5:7b
PROC_LLM_API_KEY=your_litellm_api_key_here

# ─── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jobhunter

# ─── SearXNG (self-hosted search) ────────────────────────────────────────────
# OpenRouteService (self-hosted, for commute scoring)
# Health check: $ORS_BASE_URL/ors/v2/health should return {"status":"ready"}
ORS_BASE_URL=https://ors.example.com

# Qdrant vector store (for semantic deduplication)
# Leave QDRANT_API_KEY empty for local unauthenticated instances
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=jobs_jobhunter
# Embedding model for Qdrant semantic dedup
EMBED_BASE_URL=http://localhost:11434
EMBED_API_KEY=your_embed_api_key_here
EMBED_MODEL=nomic-embed-text

# Writing/generation model (multilingual, local — requires OLLAMA_FLASH_ATTENTION=false)
WRITING_MODEL=zylonai/multilingual-e5-large:latest

# SearXNG
SEARXNG_URL=https://search.yourdomain.com

# ─── Agent email (dedicated mailbox — send-only, documents to you only) ───
AGENT_EMAIL=jobhunter@yourdomain.com
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=jobhunter@yourdomain.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM_NAME=Job Hunter

# ─── Document delivery destination ────────────────────────────────────────
# SECURITY: This is the ONLY address the agent is permitted to email.
# The agent cannot change this value — it is read directly from this file.
PERSONAL_EMAIL=you@personalemail.com

# ─── Telegram ──────────────────────────────────────────────────────────────
# Set by installer automatically — do not edit manually
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# ─── Onboarding web form ──────────────────────────────────────────────────
# Public base URL of your OpenClaw instance (used to construct the /onboard link)
OPENCLAW_BASE_URL=https://your-openclaw-domain.com
ONBOARDING_PORT=8080

# ─── OpenClaw ──────────────────────────────────────────────────────────────
OPENCLAW_AGENT_ID=jobhunter
OPENCLAW_WORKSPACE=~/.openclaw/workspace-jobhunter
