# ── Allowlist: block everything, then explicitly allow ────────────────────────
# Only files listed below will be committable.
# Anything the agent writes that isn't here is automatically blocked.
*

# ── Root files ────────────────────────────────────────────────────────────────
!.gitignore
!.env.example
!README.md
!AGENTS.md
!CLAUDE.md
!HEARTBEAT.md
!IDENTITY.md
!SOUL.md
!TOOLS.md
!requirements.txt
!install.sh

# ── Config (templates only — personal data stays local) ───────────────────────
!/config/
!config/openclaw.template.json
!config/profile.example.json
!config/preferences.example.json

# ── Source directories ─────────────────────────────────────────────────────────
!/cron/
!/cron/**
!/db/
!/db/**
!/docs/
!/docs/**
!/install/
!/install/**
!/patches/
!/patches/**
!/scripts/
!/scripts/**
!/skills/
!/skills/**

# ── Re-block generated/runtime files inside allowed dirs ──────────────────────
**/__pycache__/
**/*.py[cod]
**/*.pyo
