# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
**/*.key
**/*.pem
**/secrets*

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── OpenClaw runtime — generated by the agent, not part of the repo ──────────
memory/              # daily memory logs (memory/YYYY-MM-DD.md)
MEMORY.md            # curated long-term memory (agent-written)
BOOTSTRAP.md         # one-time first-run ritual (agent-written, deleted after use)
BOOT.md              # startup checklist (agent-written)
canvas/              # Canvas UI files
.openclaw/           # any nested openclaw state written into the workspace
sessions/            # session transcripts

# ─── JobHunter runtime — personal data and generated files ────────────────────
tmp/                 # document staging area (CV/CL before delivery)
config/profile.json  # personal profile — populated by onboarding
config/preferences.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Skills lockfile ──────────────────────────────────────────────────────────
.clawhub/