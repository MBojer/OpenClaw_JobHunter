# ─── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
**/*.key
**/*.pem
**/secrets*

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ─── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── OpenClaw runtime — generated by the agent, not part of the repo ──────────
# daily memory logs (memory/YYYY-MM-DD.md)
memory/
# curated long-term memory (agent-written)
MEMORY.md
# one-time first-run ritual (agent-written, deleted after use)
BOOTSTRAP.md
# startup checklist (agent-written)
BOOT.md
# Canvas UI files
canvas/
# any nested openclaw state written into the workspace
.openclaw/
# session transcripts
sessions/

# ─── JobHunter runtime — personal data and generated files ────────────────────
# document staging area (CV/CL before delivery)
tmp/
# personal profile — populated by onboarding
config/profile.json
config/preferences.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Skills lockfile ──────────────────────────────────────────────────────────
.clawhub/

# ─── Claude ──────────────────────────────────────────────────────────
.claude/